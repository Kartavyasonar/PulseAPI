# Gateway
NODE_ENV=production
PORT=3000
JWT_SECRET=supersecretjwtkey123
ADMIN_KEY=admin-secret-key

# Infrastructure (Docker Compose defaults)
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://pulse:pulse@postgres:5432/pulseapi

# Tracing
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Kafka async logging pipeline
# Set KAFKA_BROKERS to enable Kafka; omit to fall back to direct Postgres writes
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=request-logs
KAFKA_GROUP_ID=pulseapi-log-writer

# Dashboard (Vite build args)
VITE_GATEWAY_URL=http://localhost:3000
VITE_GATEWAY_WS=ws://localhost:3000/ws
VITE_ADMIN_KEY=admin-secret-key

# Test tenant API keys (dev only — plaintext for curl testing)
# free:       free-key-plaintext
# pro:        pro-key-plaintext
# enterprise: enterprise-key-plaintext
